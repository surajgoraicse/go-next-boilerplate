APP_NAME=boilerplate
APP_ENV=development
PORT=8888
FRONTEND_ORIGIN="http://localhost:3000"

# logging
LOG_LEVEL=debug
LOG_FILE=logs/server.log
FILE_LOG_LEVEL=debug
LOG_MAX_SIZE_MB=100
LOG_MAX_BACKUPS=5
LOG_MAX_AGE_DAYS=7

# database
DB_HOST=localhost
DB_PORT=5434
DB_USER=postgres
DB_PASSWORD=mysecretpassword
DB_NAME=boilerplate
DB_SSL_MODE=disable # enable or disable
DB_MAX_CONN=4
DB_MIN_CONN=0
DB_CONN_MAX_LIFETIME=30m
DB_CONN_MAX_IDLE_LIFETIME=5m  
DB_HEALTH_CHECK_PERIOD=30s
DB_CONNECT_TIMEOUT=5s

# google oauth
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URL="http://localhost:8888/api/v1/auth/google/callback"
GOOGLE_OIDC_ISSUER="https://accounts.google.com"

# email service
EMAIL_SERVICE_BASE_URL=http://localhost:3000
EMAIL_SERVICE_TOKEN=your_email_service_token_here
EMAIL_PROVIDER=GMAIL # GMAIL or SES
VERIFICATION_EMAIL_EXPIRY=15m
VERIFY_EMAIL_TEMPLATE_ID=14
VERIFICATION_EMAIL_RESEND_RETRY_LIMIT=2
VERIFICATION_EMAIL_RATE_LIMIT=5  # example : 5 req/day (the unit is in days)

# auth
JWT_SECRET=something_really_strong
ACCESS_TOKEN_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=168h

LOG_LEVEL=debug
FILE_LOG_LEVEL=debug

# AWS S3 Configuration
AWS_REGION=ap-south-1
AWS_S3_BUCKET=swags-me-assets
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...
PRESIGNED_URL_EXPIRY=300        # 5 minutes
UPLOAD_MAX_FILE_SIZE=5242880    # 5 MB in bytes

# OTP Configuration for Password Reset
OTP_RESEND_COOLDOWN_MINUTES=2           # Cooldown period between OTP resend requests
OTP_PASSWORD_RESET_DAILY_LIMIT=5        # Maximum OTP requests per user per day
OTP_EXPIRY_MINUTES=10                   # OTP validity duration
OTP_MAX_ATTEMPTS=3                      # Maximum verification attempts per OTP
VERIFICATION_SESSION_EXPIRY_MINUTES=10  # Session validity after OTP verification
PASSWORD_RESET_OTP_TEMPLATE_ID=13        # Email template ID for password reset OTP