DB_MAX_CONN=4
DB_MIN_CONN=0
DB_CONN_MAX_LIFETIME=30m
DB_CONN_MAX_IDLE_LIFETIME=5m  
DB_HEALTH_CHECK_PERIOD=30s
DB_CONNECT_TIMEOUT=5s

# google oauth
