APP_NAME=boilerplate
APP_ENV=development
PORT=8888
FRONTEND_ORIGIN=http://localhost:3000

# auth
JWT_SECRET=something_really_strong
ACCESS_TOKEN_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=168h
MAX_ACTIVE_DEVICES=3

# logging
LOG_LEVEL=debug
LOG_FILE=logs/server.log
FILE_LOG_LEVEL=debug
LOG_MAX_SIZE_MB=100
LOG_MAX_BACKUPS=5
LOG_MAX_AGE_DAYS=7
LOG_LEVEL=debug
FILE_LOG_LEVEL=debug

# database
DB_HOST=localhost
DB_PORT=5432
